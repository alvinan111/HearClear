@@ -62,6 +63,23 @@ std::shared_ptr<AudioBus> RecorderAdapterNode::processNode(
 
   readFrames(framesToProcess);
 
+  if (AudioAPIGetSpeechEnhancementEnabled() && AudioAPIGetSpeechEnhancementProcessor()) {
+    std::shared_ptr<BaseAudioContext> context = context_.lock();
+    if (context) {
+      float *ch0 = adapterOutputBus_->getChannel(0)->getData();
+      int frames = static_cast<int>(framesToProcess);
+      int channels = channelCount_;
+      float sampleRate = context->getSampleRate();
+      AudioAPIGetSpeechEnhancementProcessor()(ch0, frames, channels, sampleRate);
+      if (channels > 1) {
+        for (int c = 1; c < channels; ++c) {
+          float *dst = adapterOutputBus_->getChannel(c)->getData();
+          for (int i = 0; i < frames; ++i) dst[i] = ch0[i];
+        }
+      }
+    }
+  }
+
   processingBus->sum(adapterOutputBus_.get(), ChannelInterpretation::SPEAKERS);
   return processingBus;
 }
diff --git a/node_modules/react-native-audio-api/common/cpp/audioapi/core/utils/SpeechEnhancementHook.cpp b/node_modules/react-native-audio-api/common/cpp/audioapi/core/utils/SpeechEnhancementHook.cpp
new file mode 100644
index 0000000..f7f1ae9
--- /dev/null
+++ b/node_modules/react-native-audio-api/common/cpp/audioapi/core/utils/SpeechEnhancementHook.cpp
@@ -0,0 +1,27 @@
+#include <audioapi/core/utils/SpeechEnhancementHook.h>
+#include <atomic>
+
+namespace {
+std::atomic<int> g_speech_enhancement_enabled{0};
+AudioAPISpeechEnhancementProcessFn g_speech_enhancement_process = nullptr;
+} // namespace
+
+extern "C" {
+
+void AudioAPISetSpeechEnhancementEnabled(int enabled) {
+  g_speech_enhancement_enabled.store(enabled ? 1 : 0, std::memory_order_release);
+}
+
+void AudioAPISetSpeechEnhancementProcessor(AudioAPISpeechEnhancementProcessFn fn) {
+  g_speech_enhancement_process = fn;
+}
+
+int AudioAPIGetSpeechEnhancementEnabled(void) {
+  return g_speech_enhancement_enabled.load(std::memory_order_acquire);
+}
+
+AudioAPISpeechEnhancementProcessFn AudioAPIGetSpeechEnhancementProcessor(void) {
+  return g_speech_enhancement_process;
+}
+
+} // extern "C"
diff --git a/node_modules/react-native-audio-api/common/cpp/audioapi/core/utils/SpeechEnhancementHook.h b/node_modules/react-native-audio-api/common/cpp/audioapi/core/utils/SpeechEnhancementHook.h
new file mode 100644
index 0000000..031fca8
--- /dev/null
+++ b/node_modules/react-native-audio-api/common/cpp/audioapi/core/utils/SpeechEnhancementHook.h
@@ -0,0 +1,24 @@
+#pragma once
+
+#ifdef __cplusplus
+extern "C" {
+#endif
+
+/** 1 = enabled, 0 = disabled. When enabled and processor is set, RecorderAdapterNode will call the processor. */
+void AudioAPISetSpeechEnhancementEnabled(int enabled);
+
+/** Process buffer in place. monoOrCh0: channel 0 (or mono) float buffer; frames: number of frames; channels: total channels (processor may only modify ch0, caller can copy to other channels); sampleRate: Hz. */
+typedef void (*AudioAPISpeechEnhancementProcessFn)(float *monoOrCh0, int frames, int channels, float sampleRate);
+
+/** Set the processor. Pass NULL to clear. Called from SpeechEnhancement native module (e.g. sherpa-onnx + GTCRN). */
+void AudioAPISetSpeechEnhancementProcessor(AudioAPISpeechEnhancementProcessFn fn);
+
+/** For use by RecorderAdapterNode: 1 if enabled, 0 otherwise. */
+int AudioAPIGetSpeechEnhancementEnabled(void);
+
+/** For use by RecorderAdapterNode: current processor or NULL. */
+AudioAPISpeechEnhancementProcessFn AudioAPIGetSpeechEnhancementProcessor(void);
+
+#ifdef __cplusplus
+}
+#endif
