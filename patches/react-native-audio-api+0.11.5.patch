+#pragma once
+
+#ifdef __cplusplus
+extern "C" {
+#endif
+
+/** 1 = enabled, 0 = disabled. When enabled and processor is set, RecorderAdapterNode will call the processor. */
+void AudioAPISetSpeechEnhancementEnabled(int enabled);
+
+/** Process buffer in place. monoOrCh0: channel 0 (or mono) float buffer; frames: number of frames; channels: total channels (processor may only modify ch0, caller can copy to other channels); sampleRate: Hz. */
+typedef void (*AudioAPISpeechEnhancementProcessFn)(float *monoOrCh0, int frames, int channels, float sampleRate);
+
+/** Set the processor. Pass NULL to clear. Called from SpeechEnhancement native module (e.g. sherpa-onnx + GTCRN). */
+void AudioAPISetSpeechEnhancementProcessor(AudioAPISpeechEnhancementProcessFn fn);
+
+/** For use by RecorderAdapterNode: 1 if enabled, 0 otherwise. */
+int AudioAPIGetSpeechEnhancementEnabled(void);
+
+/** For use by RecorderAdapterNode: current processor or NULL. */
+AudioAPISpeechEnhancementProcessFn AudioAPIGetSpeechEnhancementProcessor(void);
+
+#ifdef __cplusplus
+}
+#endif
