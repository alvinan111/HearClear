@@ -0,0 +1,27 @@
+#include <audioapi/core/utils/SpeechEnhancementHook.h>
+#include <atomic>
+
+namespace {
+std::atomic<int> g_speech_enhancement_enabled{0};
+AudioAPISpeechEnhancementProcessFn g_speech_enhancement_process = nullptr;
+} // namespace
+
+extern "C" {
+
+void AudioAPISetSpeechEnhancementEnabled(int enabled) {
+  g_speech_enhancement_enabled.store(enabled ? 1 : 0, std::memory_order_release);
+}
+
+void AudioAPISetSpeechEnhancementProcessor(AudioAPISpeechEnhancementProcessFn fn) {
+  g_speech_enhancement_process = fn;
+}
+
+int AudioAPIGetSpeechEnhancementEnabled(void) {
+  return g_speech_enhancement_enabled.load(std::memory_order_acquire);
+}
+
+AudioAPISpeechEnhancementProcessFn AudioAPIGetSpeechEnhancementProcessor(void) {
+  return g_speech_enhancement_process;
+}
+
+} // extern "C"
